############################################
# 基础系统 & 编辑器
############################################

# Windows
Thumbs.db
Desktop.ini

# VS / VS Code
.vs/
.vscode/

############################################
# CMake / Build 产物
############################################

# CMake build directories
build/
out/
cmake-build-*/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile

############################################
# Visual Studio CMake / MSVC
############################################

*.sln
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
*.VC.db
*.VC.opendb
*.ilk
*.pdb
*.idb
*.ipdb
*.iobj
*.obj
*.exe
*.dll
*.lib
*.exp

############################################
# 编译中间文件
############################################

*.o
*.a
*.lo
*.la
*.tmp
*.log

############################################
# Python（如果你后面有脚本/工具）
############################################

__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/

############################################
# Whisper / ASR 相关（非常关键）
############################################

# Whisper 模型文件（非常大，不进 Git）
*.bin
*.gguf
*.pt
*.onnx

# Whisper runtime cache / logs
runtime/whisper/*.log
runtime/whisper/cache/
runtime/whisper/models/

############################################
# 音频 / 测试数据（建议不进 Git）
############################################

*.wav
*.mp3
*.flac
*.aac
*.m4a

############################################
# OS / 其他杂项
############################################

.DS_Store
*.swp
*.bak
*.old
*.orig

############################################
# 允许显式保留的关键源码（防止误伤）
############################################

!**/*.h
!**/*.hpp
!**/*.c
!**/*.cpp
!**/*.cmake
!CMakeLists.txt
